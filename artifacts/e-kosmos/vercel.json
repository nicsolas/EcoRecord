{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@5.0.0",
      "maxDuration": 30
    },
    "api/ping.ts": {
      "runtime": "@vercel/node@5.0.0"
    }
  },
  "rewrites": [
    {
      "source": "/api/ping",
      "destination": "/api/ping.ts"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
