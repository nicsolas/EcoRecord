{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/e-kosmos run build",
  "outputDirectory": "artifacts/e-kosmos/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
